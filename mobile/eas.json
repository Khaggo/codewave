{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://api.autocare-cc.com",
        "EXPO_PUBLIC_ECOMMERCE_API_BASE_URL": "https://ecommerce.autocare-cc.com"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://api.autocare-cc.com",
        "EXPO_PUBLIC_ECOMMERCE_API_BASE_URL": "https://ecommerce.autocare-cc.com"
      },
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
