NODE_ENV=development

MAIN_SERVICE_PORT=3000
ECOMMERCE_SERVICE_PORT=3001
CORS_ORIGINS=http://localhost:3002,http://127.0.0.1:3002,http://localhost:8081,http://127.0.0.1:8081,http://localhost:8085,http://127.0.0.1:8085,http://localhost:8090,http://127.0.0.1:8090

DATABASE_URL=postgresql://admin:root@localhost:5433/codewave

JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
AUTH_BYPASS_CUSTOMER_REGISTRATION_OTP=false

REDIS_HOST=localhost
REDIS_PORT=6379

RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_QUEUE=autocare_events

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

RESEND_API_KEY=
RESEND_FROM_EMAIL=no-reply@example.com
RESEND_FROM_NAME=AUTOCARE
RESEND_REPLY_TO=
RESEND_REQUEST_TIMEOUT_MS=15000

PAYMONGO_PUBLIC_KEY=
PAYMONGO_SECRET_KEY=
PAYMONGO_WEBHOOK_SECRET=
PAYMONGO_BOOKING_WEBHOOK_SECRET=
PAYMONGO_SERVICE_INVOICE_WEBHOOK_SECRET=
PAYMONGO_ECOMMERCE_WEBHOOK_SECRET=
PAYMONGO_CHECKOUT_SUCCESS_URL=
PAYMONGO_CHECKOUT_CANCEL_URL=
