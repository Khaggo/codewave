NODE_ENV=production
PORT=3000
# If your Railway services use different names, replace Postgres / Redis / RabbitMQ below.
DATABASE_URL=${{Postgres.DATABASE_URL}}
JWT_ACCESS_SECRET=${{ secret(64) }}
JWT_REFRESH_SECRET=${{ secret(64) }}
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
RABBITMQ_URL=amqp://${{RabbitMQ.RABBITMQ_DEFAULT_USER}}:${{RabbitMQ.RABBITMQ_DEFAULT_PASS}}@${{RabbitMQ.RAILWAY_PRIVATE_DOMAIN}}:5672
RABBITMQ_QUEUE=autocare_events
REDIS_URL=${{Redis.REDIS_URL}}
REDIS_HOST=${{Redis.REDISHOST}}
REDIS_PORT=${{Redis.REDISPORT}}
REDIS_USERNAME=${{Redis.REDISUSER}}
REDIS_PASSWORD=${{Redis.REDISPASSWORD}}
CORS_ORIGINS=https://autocare-cc.com
GOOGLE_CLIENT_ID=
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=AUTOCARE <no-reply@autocare-cc.com>
