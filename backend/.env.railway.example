NODE_ENV=production
PORT=3000
# If your Railway services use different names, replace Postgres / Redis / RabbitMQ below.
DATABASE_URL=${{Postgres.DATABASE_URL}}
JWT_ACCESS_SECRET=${{ secret(64) }}
JWT_REFRESH_SECRET=${{ secret(64) }}
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
# Explicitly set to false later when transactional email is healthy again.
AUTH_BYPASS_CUSTOMER_REGISTRATION_OTP=true
REDIS_URL=${{Redis.REDIS_URL}}
REDIS_HOST=${{Redis.REDISHOST}}
REDIS_PORT=${{Redis.REDISPORT}}
REDIS_USERNAME=${{Redis.REDISUSER}}
REDIS_PASSWORD=${{Redis.REDISPASSWORD}}
CORS_ORIGINS=https://autocare-cc.com
GOOGLE_CLIENT_ID=
RESEND_API_KEY=
RESEND_FROM_EMAIL=no-reply@autocare-cc.com
RESEND_FROM_NAME=AUTOCARE
RESEND_REPLY_TO=
RESEND_REQUEST_TIMEOUT_MS=15000
PAYMONGO_PUBLIC_KEY=
PAYMONGO_SECRET_KEY=
PAYMONGO_WEBHOOK_SECRET=
PAYMONGO_BOOKING_WEBHOOK_SECRET=
PAYMONGO_SERVICE_INVOICE_WEBHOOK_SECRET=
PAYMONGO_ECOMMERCE_WEBHOOK_SECRET=
PAYMONGO_CHECKOUT_SUCCESS_URL=https://autocare-cc.com/bookings/payment/success
PAYMONGO_CHECKOUT_CANCEL_URL=https://autocare-cc.com/bookings/payment/cancel
# Optional once Railway resources allow RabbitMQ:
# RABBITMQ_URL=amqp://${{RabbitMQ.RABBITMQ_DEFAULT_USER}}:${{RabbitMQ.RABBITMQ_DEFAULT_PASS}}@${{RabbitMQ.RAILWAY_PRIVATE_DOMAIN}}:5672
# RABBITMQ_QUEUE=autocare_events
